#!/usr/bin/env bash
#
# Pre-commit hook: block commits containing secrets.
# Scans only added lines in staged diffs.
#

PATTERNS_PERL=(
  # Telegram bot tokens
  'TELEGRAM_BOT_TOKEN=.*[0-9]+:AA'
  # Anthropic API keys
  'sk-ant-[a-zA-Z0-9]'
  # OpenAI API keys (negative lookahead excludes sk-ant-)
  'sk-(?!ant-)[a-zA-Z0-9-]{20,}'
  # AWS access key IDs
  '(AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}'
  # AWS secret access key assignments
  'AWS_SECRET_ACCESS_KEY[=:].{20,}'
  # API key assignments
  'ANTHROPIC_API_KEY[=:].+'
  'OPENAI_API_KEY[=:].+'
  'NPM_TOKEN[=:].+'
)

# Fallback patterns for systems without grep -P (no lookahead)
PATTERNS_ERE=(
  'TELEGRAM_BOT_TOKEN=.*[0-9]+:AA'
  'sk-ant-[a-zA-Z0-9]'
  'sk-[a-zA-Z0-9-]{20,}'
  '(AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}'
  'AWS_SECRET_ACCESS_KEY[=:].{20,}'
  'ANTHROPIC_API_KEY[=:].+'
  'OPENAI_API_KEY[=:].+'
  'NPM_TOKEN[=:].+'
)

# Known safe strings — if found anywhere in a line, that line is allowed
ALLOWED=(
  'AKIAIOSFODNN7EXAMPLE'
  'wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY'
)

# Detect grep -P support once
HAS_GREP_P=0
if echo "test" | grep -P "test" >/dev/null 2>&1; then
  HAS_GREP_P=1
fi

if [ "$HAS_GREP_P" -eq 0 ]; then
  echo "WARNING: grep -P not available. OpenAI key detection may have false positives (sk-ant- not excluded)." >&2
fi

FAILED=0

# Extract added content lines from staged diff (including renames, text only)
ADDED_LINES=$(git diff --cached --diff-filter=ACMR -U0 --text \
  | grep '^+' \
  | grep -v '^+++' \
)

if [ -z "$ADDED_LINES" ]; then
  exit 0
fi

if [ "$HAS_GREP_P" -eq 1 ]; then
  PATTERNS=("${PATTERNS_PERL[@]}")
  GREP_MODE="-P"
else
  PATTERNS=("${PATTERNS_ERE[@]}")
  GREP_MODE="-E"
fi

for pattern in "${PATTERNS[@]}"; do
  MATCHES=$(echo "$ADDED_LINES" | grep "$GREP_MODE" "$pattern" 2>/dev/null)

  if [ -n "$MATCHES" ]; then
    while IFS= read -r line; do
      content="${line:1}"

      # Check if line contains any allowed string
      IS_ALLOWED=0
      for allowed in "${ALLOWED[@]}"; do
        if [[ "$content" == *"$allowed"* ]]; then
          # Make sure the allowed string isn't a substring of a longer key
          # by checking no alphanumeric char immediately follows it
          after="${content#*"$allowed"}"
          if [ -z "$after" ] || [[ ! "$after" =~ ^[A-Za-z0-9] ]]; then
            IS_ALLOWED=1
            break
          fi
        fi
      done

      if [ "$IS_ALLOWED" -eq 0 ]; then
        # Deduplicate: if ERE mode and this is the broad sk- pattern,
        # skip lines already matched by the sk-ant- pattern
        if [ "$GREP_MODE" = "-E" ] && [[ "$pattern" == 'sk-[a-zA-Z0-9-]'* ]] && [[ "$content" == *"sk-ant-"* ]]; then
          continue
        fi
        FAILED=1
        echo "ERROR: Possible secret matching '$pattern':"
        echo "  $content"
      fi
    done <<< "$MATCHES"
  fi
done

if [ "$FAILED" -eq 1 ]; then
  echo ""
  echo "Commit blocked. Remove secrets before committing."
  echo "To bypass (dangerous): git commit --no-verify"
  exit 1
fi

exit 0
