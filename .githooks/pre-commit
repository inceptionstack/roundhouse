#!/usr/bin/env bash
#
# Pre-commit hook: block commits containing secrets.
# Scans only added lines in staged diffs.
#

PATTERNS=(
  # Telegram bot tokens
  'TELEGRAM_BOT_TOKEN=.*[0-9]+:AA'
  # Anthropic API keys
  'sk-ant-[a-zA-Z0-9]'
  # OpenAI API keys (negative lookahead excludes sk-ant-)
  'sk-(?!ant-)[a-zA-Z0-9-]{20,}'
  # AWS access key IDs
  '(AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}'
  # AWS secret access key assignments
  'AWS_SECRET_ACCESS_KEY[=:].{20,}'
  # API key assignments
  'ANTHROPIC_API_KEY[=:].+'
  'OPENAI_API_KEY[=:].+'
  'NPM_TOKEN[=:].+'
)

# Known safe example strings (exact match only)
ALLOWED=(
  'AKIAIOSFODNN7EXAMPLE'
  'wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY'
)

FAILED=0

# Extract only added content lines from staged diff
# - Lines starting with + (excluding +++ headers)
# - Skip comment lines and quoted pattern definitions (avoids self-match in hook files)
ADDED_LINES=$(git diff --cached --diff-filter=ACM -U0 \
  | grep '^+' \
  | grep -v '^+++' \
  | grep -v "^+[[:space:]]*#" \
  | grep -v "^+[[:space:]]*'" \
)

if [ -z "$ADDED_LINES" ]; then
  exit 0
fi

for pattern in "${PATTERNS[@]}"; do
  # Use -P (perl regex) for lookahead support, fall back to -E
  MATCHES=$(echo "$ADDED_LINES" | grep -P "$pattern" 2>/dev/null)
  if [ -z "$MATCHES" ]; then
    MATCHES=$(echo "$ADDED_LINES" | grep -E "$pattern" 2>/dev/null)
  fi

  if [ -n "$MATCHES" ]; then
    while IFS= read -r line; do
      # Strip leading + to get actual content
      content="${line:1}"

      # Exact match against allowlist (not substring)
      IS_ALLOWED=0
      for allowed in "${ALLOWED[@]}"; do
        if [ "$content" = "$allowed" ]; then
          IS_ALLOWED=1
          break
        fi
      done

      if [ "$IS_ALLOWED" -eq 0 ]; then
        FAILED=1
        echo "ERROR: Possible secret matching '$pattern':"
        echo "  $content"
      fi
    done <<< "$MATCHES"
  fi
done

if [ "$FAILED" -eq 1 ]; then
  echo ""
  echo "Commit blocked. Remove secrets before committing."
  echo "To bypass (dangerous): git commit --no-verify"
  exit 1
fi

exit 0
